{
  "browser": "chromium",
  "headless": true,
  "environment": "local",
  "iteration": 1,
  "outputDir": "results",
  "name": "EXAMPLE",
  "startUrl": "https://example.com",
  "targets": [],
  "crawl": {
    "enabled": true,
    "maxDepth": 2,
    "maxPages": 50,
    "includeExternalDomains": false,
    "allowedDomains": [
      "example.com"
    ]
  },
  "elasticsearch": {
    "enabled": false,
    "indexPrefix": "quality-signal"
  },
  "consent": {
    "enabled": true,
    "timeoutMs": 1500
  },
  "assuranceModules": {
    "enabled": {
      "clientErrors": true,
      "uxFriction": true,
      "memoryLeaks": true,
      "cacheAnalysis": true,
      "thirdPartyResilience": true,
      "privacyAudit": true,
      "runtimeSecurity": true,
      "dependencyRisk": true,
      "regressionDelta": true
    }
  }
}
