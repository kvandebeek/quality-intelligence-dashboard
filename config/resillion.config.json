{
  "browser": "chromium",
  "headless": true,
  "environment": "local",
  "iteration": 1,
  "outputDir": "artifacts",
  "name": "RESILLION",
  "startUrl": "https://www.resillion.com",
  "targets": [],
  "crawl": {
