{
  "browser": "chromium",
  "headless": true,
  "environment": "local",
  "iteration": 1,
  "outputDir": "artifacts",
  "name": "RESILLION",
  "startUrl": "https://resillion.com",
  "targets": [
    {
      "name": "Resillion Landing Page",
      "url": "https://resillion.com"
    }
  ],
  "crawl": {
    "enabled": false,
    "maxDepth": 2,
    "maxPages": 50,
    "includeExternalDomains": false,
    "allowedDomains": ["resillion.com"]
  },
  "elasticsearch": {
    "enabled": false,
    "indexPrefix": "cx-assurance"
  }
}
