{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["meta", "payload"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["runId", "url", "urlSlug", "timestamp", "toolVersion", "schemaVersion"],
      "properties": {
        "runId": {"type": "string"},
        "url": {"type": "string"},
        "urlSlug": {"type": "string"},
        "timestamp": {"type": "string"},
        "toolVersion": {"type": "string"},
        "schemaVersion": {"type": "string"}
      }
    },
    "payload": {
      "type": "object",
      "required": ["keyboardReachable", "possibleFocusTrap", "contrastSimulationScore"],
      "properties": {
        "keyboardReachable": {"type": "boolean"},
        "possibleFocusTrap": {"type": "boolean"},
        "possibleFocusTrapDetails": {
          "type": "object",
          "properties": {
            "candidates": {
              "type": "array",
              "items": {"type": "object"}
            }
          },
          "required": ["candidates"]
        },
        "contrastSimulationScore": {"type": ["number", "null"]},
        "contrastSimulationScoreReason": {"type": ["string", "null"]},
        "contrastSimulationDetails": {
          "type": "object",
          "properties": {
            "method": {"type": "object"},
            "findings": {
              "type": "array",
              "items": {"type": "object"}
            }
          },
          "required": ["method", "findings"]
        }
      }
    }
  }
}
